#include <iostream>
using namespace std;

int main() {

    int n;
    cout << "Cantidad de numeros: ";
    cin >> n;

    int numeros[100]; 

    for(int i = 0; i < n; i++) {
        cout << "Ingresa un numero: ";
        cin >> numeros[i];
    }

    int maximo = numeros[0];

    for(int i = 1; i < n; i++) {
        if(numeros[i] > maximo) {
            maximo = numeros[i];
        }
    }

    cout << "El numero maximo es: " << maximo << endl;

    return 0;
}
