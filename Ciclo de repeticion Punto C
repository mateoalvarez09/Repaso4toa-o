#include <iostream>
using namespace std;

int main() {

    int num;
    int suma = 0;

    cout << "ingresa numeros positivos (negativo para terminar): ";
    cin >> num;

    while(num >= 0) {
        suma = suma + num;
        cin >> num;
    }

    cout << "la suma total seria: " << suma << endl;

    return 0;
}
