#include <iostream>
using namespace std;

int main() {

    int n;
    int suma = 0;

    cout << "Cantidad de numeros: ";
    cin >> n;

    int arr[100];

    
    for(int i = 0; i < n; i++) {
        cout << "Ingresa un numero: ";
        cin >> arr[i];
    }

    for(int i = 0; i < n; i++) {
        suma = suma + arr[i];
    }

    cout << "La suma total es: " << suma << endl;

    return 0;
}
