#include <iostream>
using namespace std;

int main() {

    int num;
    int producto = 1;

    cout << "ingresa numeros positivos (negativo para terminar): ";
    cin >> num;

    while(num >= 0) {
        producto = producto * num;
        cin >> num;
    }

    cout << "el producto total es: " << producto << endl;

    return 0;
}
